{
  "name": "spendyes",
  "version": "3.0.0",
  "description": "SpendYes - Spending Confidence Engine",
  "main": "server/v3-server.js",
  "scripts": {
    "start": "node server/v5/index.js",
    "start:v4": "node server/v4/index.js",
    "start:v3": "node server/migrate-v3.js && node server/v3-server.js",
    "dev": "node --watch server/v5/index.js",
    "test:v5": "node server/v5/tests/run.js",
    "test:v4": "node server/v4/tests/run.js",
    "test": "node server/v5/tests/run.js",
    "test:v3": "node server/tests/v3-engine.test.js",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@prisma/client": "5.22.0",
    "dotenv": "^17.4.0",
    "express": "^4.18.0",
    "grammy": "^1.21.0",
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "prisma": "5.22.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
