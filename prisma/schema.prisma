// Vera v2 — Database Schema
// All monetary values in INTEGER CENTS. No floating point anywhere.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -- User --
model User {
  id         String   @id @default(cuid())
  telegramId String?  @unique
  webToken   String?  @unique @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Core state (the "balance sheet")
  setup          Boolean @default(false)
  balanceCents   Int     @default(0)
  incomeCents    Int     @default(0)
  savingsCents   Int     @default(0)
  savingRateBps  Int     @default(0)
  payday         String?
  cycleStart     String?
  currency       String  @default("USD")
  currencySymbol String  @default("$")
  localRate      Int     @default(100)

  // Relations
  drains           Drain[]
  pools            Pool[]
  plannedPurchases PlannedPurchase[]
  transactions     Transaction[]
  monthlies        MonthlySummary[]
  cycles           CycleSummary[]
  messages         Message[]

  @@index([telegramId])
  @@index([webToken])
}

// -- Drain (recurring bill / obligation) --
model Drain {
  id            String  @id @default(cuid())
  userId        String
  key           String
  name          String
  amountCents   Int
  intervalDays  Int     @default(30)
  nextDate      String?
  active        Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}

// -- Pool (spending category with budget) --
model Pool {
  id             String   @id @default(cuid())
  userId         String
  key            String
  name           String
  type           String   @default("daily")
  dailyCents     Int      @default(0)
  allocatedCents Int      @default(0)
  keywords       String[]
  spentCents     Int      @default(0)
  active         Boolean  @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}

// -- Planned Purchase (reserved future spend) --
model PlannedPurchase {
  id          String  @id @default(cuid())
  userId      String
  key         String
  name        String
  amountCents Int
  date        String?
  confirmed   Boolean @default(false)
  active      Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}

// -- Transaction --
model Transaction {
  id          String   @id @default(cuid())
  userId      String
  type        String
  amountCents Int
  description String   @default("")
  node        String?
  date        String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, node])
  @@index([userId, type])
}

// -- Monthly Summary (graph node: one per user per month per pool) --
// Pre-computed aggregates. Updated on every transaction.
model MonthlySummary {
  id          String @id @default(cuid())
  userId      String
  month       String // "2026-04"
  poolKey     String // pool key, "_total", or "_free"
  spentCents  Int    @default(0)
  earnedCents Int    @default(0)
  txCount     Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, poolKey])
  @@index([userId, month])
  @@index([userId, poolKey])
}

// -- Cycle Summary (archived snapshot when pay cycle ends) --
model CycleSummary {
  id              String   @id @default(cuid())
  userId          String
  cycleStart      String
  cycleEnd        String
  incomeCents     Int
  totalSpentCents Int
  savedCents      Int
  poolSpend       Json     // { "food": 45000, "transport": 12000 }
  drainsPaid      Json     // { "rent": 123700, "gym": 5500 }
  txCount         Int
  