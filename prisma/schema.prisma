// Vera V3 — Database Schema
// All monetary values in INTEGER CENTS. No floating point anywhere.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -- User --
model User {
  id         String   @id @default(cuid())
  telegramId String?  @unique
  webToken   String?  @unique @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Core state
  setup          Boolean @default(false)
  balanceCents   Int     @default(0)
  incomeCents    Int     @default(0)
  payday         String?
  cycleStart     String?
  currency       String  @default("USD")
  currencySymbol String  @default("$")
  language       String  @default("en")

  // Relations
  envelopes    Envelope[]
  transactions Transaction[]
  monthlies    MonthlySummary[]
  cycles       CycleSummary[]
  messages     Message[]

  @@index([telegramId])
  @@index([webToken])
}

// -- Envelope (one primitive for bills, budgets, savings, goals) --
model Envelope {
  id              String   @id @default(cuid())
  userId          String
  key             String
  name            String
  rhythm          String   // daily, weekly, monthly, on_income, once, ongoing
  amountCents     Int      @default(0)
  targetCents     Int?
  fundedCents     Int      @default(0)
  spentCents      Int      @default(0)
  fundRate        Int?     // basis points for % auto-fund (1000 = 10%)
  fundAmountCents Int?     // cents for fixed auto-fund
  intervalDays    Int      @default(30)
  nextDate        String?
  keywords        String[] @default([])
  priority        String   @default("flexible") // essential | flexible
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}

// -- Transaction --
model Transaction {
  id          String   @id @default(cuid())
  userId      String
  type        String   // spend, refund, income, correction, pay_envelope, fund_envelope
  amountCents Int
  description String   @default("")
  envelope    String?  // envelope key (was "node" in v2)
  date        String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, envelope])
  @@index([userId, type])
}

// -- Monthly Summary (one per user per month per envelope) --
// Pre-computed aggregates. Updated on every transaction.
model MonthlySummary {
  id          String @id @default(cuid())
  userId      String
  month       String // "2026-04"
  envelopeKey String // envelope key, "_total", or "_free"
  spentCents  Int    @default(0)
  earnedCents Int    @default(0)
  txCount     Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, envelopeKey])
  @@index([userId, month])
  @@index([userId, envelopeKey])
}

// -- Cycle Summary (archived snapshot when pay cycle ends) --
model CycleSummary {
  id              String   @id @default(cuid())
  userId          String
  cycleStart      String
  cycleEnd        String
  incomeCents     Int
  totalSpentCents Int
  savedCents      Int
  envelopeSpend   Json     // { "groceries": 45000, "coffee": 12000 }
  txCount         Int
  daysInCycle     Int
  avgDailySpend   Int
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, cycleStart])
}

// -- Message (conversation history) --
model Message {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// -- API Call Log (cost tracking) --
model ApiLog {
  id            String   @id @default(cuid())
  userId        String?
  model         String
  promptTokens  Int      @default(0)
  outputTokens  Int      @default(0)
  totalTokens   Int      @default(0)
  costCents     Int      @default(0)
  endpoint      String   @default("chat")
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([model])
}
