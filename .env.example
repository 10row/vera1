# Vera — Environment Variables
# Copy to .env for local dev. On Railway, set these in the dashboard.

# Telegram
BOT_TOKEN=           # from @BotFather on Telegram

# Anthropic (Claude API)
ANTHROPIC_API_KEY=   # from console.anthropic.com

# OpenAI (Whisper for voice transcription)
OPENAI_API_KEY=      # from platform.openai.com

# Database — Railway provides this automatically when you add a Postgres plugin
# For local dev: postgresql://user:password@localhost:5432/vera
DATABASE_URL=

# Your Railway app URL — set after first deploy
# e.g. https://vera-production-xxxx.up.railway.app
WEBHOOK_URL=https://YOUR-RAILWAY-URL/telegram/webhook
MINIAPP_URL=https://YOUR-RAILWAY-URL/miniapp

# Server
PORT=3000
NODE_ENV=production
