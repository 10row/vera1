# SpendYes v2 — Environment Variables
# Copy to .env for local dev. On Railway, set these in the dashboard.

# Anthropic (Claude API) — required for chat
ANTHROPIC_API_KEY=

# Database — Railway provides this automatically when you add a Postgres plugin
# For local dev: postgresql://user:password@localhost:5432/spendyes
DATABASE_URL=

# Server (Railway injects PORT automatically)
PORT=3000
